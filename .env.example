# Salin file ini menjadi .env lalu isi nilainya

# Server
PORT=3000

# PostgreSQL — contoh: postgres://user:password@localhost:5432/meow_lebaran
DATABASE_URL=postgres://user:password@localhost:5432/meow_lebaran

# Z.ai / ZhipuAI — daftar di https://bigmodel.cn → API Keys
GLM_API_KEY=your_glm_api_key_here

# Google Gemini API — daftar di https://makersuite.google.com → API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Sumopod API — daftar di https://sumopod.com → API Keys
SUMOPOD_API_KEY=your_sumopod_api_key_here

# URL Dana Kaget untuk reward setelah user kirim komentar
DANA_KAGET_URL=https://link.dana.id/kaget?c=your_code_here

# Nama pemilik website (tampil di footer & banner Dana Kaget)
SITE_OWNER=Nama Kamu
